pipeline {

    agent any

    environment {
        DOCKER_REGISTRY  = 'your-dockerhub-username'   // ← replace this
        VERSION          = "1.0.${BUILD_NUMBER}"
        COMPOSE_FILE     = 'docker-compose.yaml'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        disableConcurrentBuilds()
    }

    triggers {
        pollSCM('H/5 * * * *')   // poll every 5 min until webhook is set up
    }

    stages {

        stage('Checkout') {
            steps {
                echo "🚀 Building ecommerce-platform v${VERSION}"
                checkout scm
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def changed = sh(
                        script: "git diff --name-only HEAD~1 HEAD 2>/dev/null || echo 'all'",
                        returnStdout: true
                    ).trim()

                    env.BUILD_GATEWAY  = changed.contains('api-gateway')     || changed == 'all' ? 'true' : 'false'
                    env.BUILD_USER     = changed.contains('user-service')     || changed == 'all' ? 'true' : 'false'
                    env.BUILD_PRODUCT  = changed.contains('product-service')  || changed == 'all' ? 'true' : 'false'
                    env.BUILD_ORDER    = changed.contains('order-service')    || changed == 'all' ? 'true' : 'false'

                    echo """
                    📦 Services to build:
                       api-gateway:     ${env.BUILD_GATEWAY}
                       user-service:    ${env.BUILD_USER}
                       product-service: ${env.BUILD_PRODUCT}
                       order-service:   ${env.BUILD_ORDER}
                    """
                }
            }
        }

        stage('Test') {
            parallel {

                stage('API Gateway') {
                    when { expression { env.BUILD_GATEWAY == 'true' } }
                    steps {
                        dir('services/api-gateway') {
                            sh '''
                                npm ci
                                npm test -- --passWithNoTests
                            '''
                        }
                    }
                }

                stage('User Service') {
                    when { expression { env.BUILD_USER == 'true' } }
                    steps {
                        dir('services/user-service') {
                            sh 'mvn test -q'
                        }
                    }
                }

                stage('Product Service') {
                    when { expression { env.BUILD_PRODUCT == 'true' } }
                    steps {
                        dir('services/product-service') {
                            sh '''
                                pip install -r requirements.txt -q
                                pip install pytest -q
                                pytest tests/ -v --tb=short || true
                            '''
                        }
                    }
                }

                stage('Order Service') {
                    when { expression { env.BUILD_ORDER == 'true' } }
                    steps {
                        dir('services/order-service') {
                            sh '''
                                go mod download
                                go test ./... -v
                            '''
                        }
                    }
                }

            }
        }

        stage('Build & Push Images') {
            parallel {

                stage('Build Gateway') {
                    when { expression { env.BUILD_GATEWAY == 'true' } }
                    steps {
                        script { buildAndPush('api-gateway') }
                    }
                }

                stage('Build User') {
                    when { expression { env.BUILD_USER == 'true' } }
                    steps {
                        script { buildAndPush('user-service') }
                    }
                }

                stage('Build Product') {
                    when { expression { env.BUILD_PRODUCT == 'true' } }
                    steps {
                        script { buildAndPush('product-service') }
                    }
                }

                stage('Build Order') {
                    when { expression { env.BUILD_ORDER == 'true' } }
                    steps {
                        script { buildAndPush('order-service') }
                    }
                }

            }
        }

        stage('Deploy') {
            steps {
                script {
                    withCredentials([
                        string(credentialsId: 'jwt-secret',    variable: 'JWT_SECRET'),
                        string(credentialsId: 'db-root-pass',  variable: 'DB_ROOT_PASS')
                    ]) {
                        sh '''
                            export JWT_SECRET=$JWT_SECRET
                            export DB_ROOT_PASS=$DB_ROOT_PASS
                            docker compose -f $COMPOSE_FILE up -d --build
                        '''
                    }
                }
            }
        }

        stage('Smoke Test') {
            steps {
                sh '''
                    echo "⏳ Waiting for services to be ready..."
                    sleep 20

                    echo "🧪 Testing API Gateway..."
                    curl -sf http://localhost:3000/health || exit 1

                    echo "🧪 Testing User Service..."
                    curl -sf http://localhost:8081/api/users/health || exit 1

                    echo "🧪 Testing Product Service..."
                    curl -sf http://localhost:8082/health || exit 1

                    echo "🧪 Testing Order Service..."
                    curl -sf http://localhost:8083/health || exit 1

                    echo "✅ All services healthy!"
                '''
            }
        }

    }

    post {
        success {
            echo "✅ Pipeline SUCCESS — ecommerce-platform v${VERSION} deployed!"
        }
        failure {
            echo "❌ Pipeline FAILED — check logs for build #${BUILD_NUMBER}"
        }
        always {
            cleanWs()
        }
    }
}

// ── Helper function ────────────────────────────────────────────────
def buildAndPush(String service) {
    withCredentials([usernamePassword(
        credentialsId: 'dockerhub-creds',
        usernameVariable: 'DOCKER_USER',
        passwordVariable: 'DOCKER_PASS'
    )]) {
        sh """
            echo "🔨 Building ${service}..."
            docker build -t ${DOCKER_REGISTRY}/${service}:${VERSION} \
                         -t ${DOCKER_REGISTRY}/${service}:latest \
                         services/${service}/

            echo "📤 Pushing ${service}..."
            echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin
            docker push ${DOCKER_REGISTRY}/${service}:${VERSION}
            docker push ${DOCKER_REGISTRY}/${service}:latest
        """
    }
}
