pipeline {
    agent any

    environment {
        DOCKER_REGISTRY  = 'santonix'
        VERSION          = "1.0.${BUILD_NUMBER}"
        
        // 1. PHYSICAL PATH BRIDGE
        // This is the path on your HOST machine. 
        // Jenkins needs to pass THIS to Docker for volume mounting to work.
        HOST_ROOT        = "/home/bonny/CLAUDE/Aplications/ecommerce-platform"
        HOST_WS          = "${HOST_ROOT}/jenkins_home/workspace/${JOB_NAME}"
        
        // 2. NETWORK NAMESPACE
        // Ensure this matches the network created by your docker-compose
        APP_NETWORK      = "ecommerce-platform_default"
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'git log --oneline -3'
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def changed = sh(script: "git diff --name-only HEAD~1 HEAD 2>/dev/null || echo 'all'", returnStdout: true).trim()
                    def buildAll = (changed == 'all' || changed.isEmpty() || currentBuild.getBuildCauses().toString().contains('UserIdCause'))

                    env.BUILD_GATEWAY = (buildAll || changed.contains('api-gateway'))     ? 'true' : 'false'
                    env.BUILD_USER    = (buildAll || changed.contains('user-service'))    ? 'true' : 'false'
                    env.BUILD_PRODUCT = (buildAll || changed.contains('product-service')) ? 'true' : 'false'
                    env.BUILD_ORDER   = (buildAll || changed.contains('order-service'))   ? 'true' : 'false'
                }
            }
        }

        stage('Test') {
            parallel {
                stage('API Gateway') {
                    when { expression { env.BUILD_GATEWAY == 'true' } }
                    steps {
                        sh "docker run --rm -v ${HOST_WS}/services/api-gateway:/app -w /app node:18-alpine sh -c 'npm ci && npm test -- --passWithNoTests --forceExit'"
                    }
                }
                stage('User Service') {
                    when { expression { env.BUILD_USER == 'true' } }
                    steps {
                        sh "docker run --rm -v ${HOST_WS}/services/user-service:/app -w /app maven:3.9-eclipse-temurin-17 mvn test -q -Dsurefire.failIfNoSpecifiedTests=false"
                    }
                }
                stage('Product Service') {
                    when { expression { env.BUILD_PRODUCT == 'true' } }
                    steps {
                        sh "docker run --rm -v ${HOST_WS}/services/product-service:/app -w /app -e PYTHONPATH=/app python:3.11-slim sh -c 'pip install -r requirements.txt pytest -q && pytest tests/ -v --tb=short'"
                    }
                }
                stage('Order Service') {
                    when { expression { env.BUILD_ORDER == 'true' } }
                    steps {
                        sh "docker run --rm -v ${HOST_WS}/services/order-service:/app -w /app golang:1.21-alpine sh -c 'go mod download && go test ./... -v'"
                    }
                }
            }
        }

        stage('Build & Push Images') {
            parallel {
                stage('Gateway') { when { expression { env.BUILD_GATEWAY == 'true' } }; steps { script { buildAndPush('api-gateway', 'services/api-gateway') } } }
                stage('User')    { when { expression { env.BUILD_USER == 'true' } };    steps { script { buildAndPush('user-service', 'services/user-service') } } }
                stage('Product') { when { expression { env.BUILD_PRODUCT == 'true' } }; steps { script { buildAndPush('product-service', 'services/product-service') } } }
                stage('Order')   { when { expression { env.BUILD_ORDER == 'true' } };   steps { script { buildAndPush('order-service', 'services/order-service') } } }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([
                    string(credentialsId: 'jwt-secret',   variable: 'JWT_SECRET'),
                    string(credentialsId: 'db-root-pass', variable: 'DB_ROOT_PASS')
                ]) {
                    sh '''
                        echo "🚀 Deploying via Docker Compose..."
                        # Use the actual file in the workspace rather than a /tmp folder
                        # This ensures the Docker Host can see the file
                        JWT_SECRET=$JWT_SECRET DB_ROOT_PASS=$DB_ROOT_PASS \
                        docker-compose -p ecommerce-platform \
                        -f /home/bonny/CLAUDE/Aplications/ecommerce-platform/docker-compose.yaml up -d --force-recreate
                    '''
                }
            }
        }

        stage('Smoke Test') {
            steps {
                script {
                    def GATEWAY_URL = "http://api-gateway:3000"
                    def maxRetries = 20
                    def waitTime = 5
                    def ready = false

                    echo "⏳ Waiting for gateway at ${GATEWAY_URL}..."

                    for (int i = 1; i <= maxRetries; i++) {
                        // We run curl inside a container on the SAME network as the app
                        def status = sh(
                            script: "docker run --rm --network ${APP_NETWORK} curlimages/curl -s -o /dev/null -w '%{http_code}' ${GATEWAY_URL}/health",
                            returnStdout: true
                        ).trim()

                        if (status == '200') {
                            echo "✅ Gateway ready!"
                            ready = true
                            break
                        }
                        echo "  ⏳ Attempt ${i}/${maxRetries} — HTTP ${status} — retrying..."
                        sleep waitTime
                    }

                    if (!ready) { error("❌ Smoke Test Failed: Gateway unreachable.") }

                    // Run the detailed functional tests within the network
                    sh """
                        docker run --rm --network ${APP_NETWORK} \
                            -e BASE_URL=${GATEWAY_URL} \
                            python:3.11-slim sh -c '
                            
                            # Simple python check for token
                            echo "🧪 Testing Auth & API flow..."
                            LOGIN_DATA=\$(curl -s -X POST \$BASE_URL/api/users/login \
                                -H "Content-Type: application/json" \
                                -d "{\\"email\\":\\"smoketest@ci.com\\",\\"password\\":\\"smokepass123\\"}")
                            
                            if echo \$LOGIN_DATA | grep -q "token"; then
                                echo "  ✅ Login/Auth Successful"
                            else
                                echo "  ❌ Login Failed: \$LOGIN_DATA"
                                exit 1
                            fi
                        '
                    """
                }
            }
        }
    }

    post {
        success { echo "🎉 ecommerce-platform v${VERSION} is live!" }
        always { cleanWs() }
    }
}

def buildAndPush(String service, String relativePath) {
    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
        sh """
            echo "🔨 Building ${service}..."
            # Build directly from workspace to ensure host visibility
            docker build -t ${DOCKER_REGISTRY}/${service}:${VERSION} -t ${DOCKER_REGISTRY}/${service}:latest ${WORKSPACE}/${relativePath}
            
            echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
            docker push ${DOCKER_REGISTRY}/${service}:${VERSION}
            docker push ${DOCKER_REGISTRY}/${service}:latest
        """
    }
}

