pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'santonix'
        VERSION         = "1.0.${BUILD_NUMBER}"
        // This is the path on the HOST where your files live
        PROJECT_ROOT    = "/home/bonny/CLAUDE/Aplications/ecommerce-platform"
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def changed = sh(script: "git diff --name-only HEAD~1 HEAD 2>/dev/null || echo 'all'", returnStdout: true).trim()
                    def buildAll = (changed == 'all' || changed.isEmpty() || currentBuild.getBuildCauses().toString().contains('UserIdCause'))

                    env.BUILD_GATEWAY = (buildAll || changed.contains('api-gateway')) ? 'true' : 'false'
                    env.BUILD_USER    = (buildAll || changed.contains('user-service')) ? 'true' : 'false'
                    env.BUILD_PRODUCT = (buildAll || changed.contains('product-service')) ? 'true' : 'false'
                    env.BUILD_ORDER   = (buildAll || changed.contains('order-service')) ? 'true' : 'false'
                }
            }
        }

        stage('Build & Push Services') {
            parallel {
                stage('Gateway') { when { expression { env.BUILD_GATEWAY == 'true' } }; steps { script { buildAndPush('api-gateway', 'services/api-gateway') } } }
                stage('User')    { when { expression { env.BUILD_USER == 'true' } };    steps { script { buildAndPush('user-service', 'services/user-service') } } }
                stage('Product') { when { expression { env.BUILD_PRODUCT == 'true' } }; steps { script { buildAndPush('product-service', 'services/product-service') } } }
                stage('Order')   { when { expression { env.BUILD_ORDER == 'true' } };   steps { script { buildAndPush('order-service', 'services/order-service') } } }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([
                    string(credentialsId: 'jwt-secret', variable: 'JWT_SECRET'),
                    string(credentialsId: 'db-root-pass', variable: 'DB_ROOT_PASS')
                ]) {
                    // Using single quotes ''' so Bash handles the variables, 
                    // except for the ones we want Jenkins to inject
                    sh '''
                        echo "🚀 Deploying from ${PROJECT_ROOT}..."
                        cd ${PROJECT_ROOT}
                        
                        # Use > to create/overwrite .env with credentials
                        echo "JWT_SECRET=${JWT_SECRET}" > .env
                        echo "DB_ROOT_PASS=${DB_ROOT_PASS}" >> .env
                        echo "NODE_ENV=production" >> .env

                        # Restart containers
                        docker-compose down --remove-orphans
                        docker-compose up -d
                        
                        sleep 10
                        docker-compose ps
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    cd ${PROJECT_ROOT}
                    echo "=== CONTAINER STATUS ==="
                    docker-compose ps
                    
                    # Basic check to see if api-gateway is running
                    if [ $(docker inspect -f '{{.State.Running}}' ecommerce-platform-api-gateway-1) = "true" ]; then
                        echo "✅ Gateway is running"
                    else
                        echo "❌ Gateway is NOT running"
                        exit 1
                    fi
                '''
            }
        }
    }

    post {
        success {
            echo "🎉 Build #${BUILD_NUMBER} deployed successfully!"
            cleanWs()
        }
        failure {
            echo "💥 Build #${BUILD_NUMBER} failed. Check console output."
        }
        // NOTE: No 'always' block deleting containers here!
    }
}

def buildAndPush(String service, String relativePath) {
    // Inside the function, we use the Jenkins workspace path
    def fullPath = "${env.WORKSPACE}/${relativePath}"
    
    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
        sh """
            echo "🔨 Building ${service}..."
            docker build -t ${env.DOCKER_REGISTRY}/${service}:${env.VERSION} -t ${env.DOCKER_REGISTRY}/${service}:latest ${fullPath}
            
            echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
            docker push ${env.DOCKER_REGISTRY}/${service}:${env.VERSION}
            docker push ${env.DOCKER_REGISTRY}/${service}:latest
        """
    }
}